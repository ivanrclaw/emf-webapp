{
  "name": "emf-webapp",
  "version": "1.0.0",
  "private": true,
  "description": "EMF WebApp — Reconstrucción web de Eclipse Modeling Framework",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws --if-present",
    "test": "npm run test -ws --if-present",
    "dev": "npm run dev -ws --if-present",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "turbo": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
